section#pillars.home-pillars.py-16
  .container.mx-auto.px-4.space-y-10
    h2.text-center.text-2xl.md:text-3xl.font-bold.text-base-content
      = t('home.index.pillars.section_title')

    .grid.grid-cols-1.md:grid-cols-3.gap-6
      .card.card-bordered.bg-base-100.shadow-md.rounded-xl.h-full
        .card-body.space-y-4.text-left.items-start
          .home-pillar-icon
            = lucide_icon 'terminal', class: 'w-6 h-6'
          h3.text-lg.font-bold.text-base-content
            = t('home.index.pillars.legacy_ai.title')
          p.text-sm.text-neutral-600.leading-relaxed
            = t('home.index.pillars.legacy_ai.body')

      .card.card-bordered.bg-base-100.shadow-md.rounded-xl.h-full
        .card-body.space-y-4.text-left.items-start
          .home-pillar-icon
            = lucide_icon 'brain', class: 'w-6 h-6'
          h3.text-lg.font-bold.text-base-content
            = t('home.index.pillars.vibe_cleanup.title')
          p.text-sm.text-neutral-600.leading-relaxed
            = t('home.index.pillars.vibe_cleanup.body')

      .card.card-bordered.bg-base-100.shadow-md.rounded-xl.h-full
        .card-body.space-y-4.text-left.items-start
          .home-pillar-icon
            = lucide_icon 'handshake', class: 'w-6 h-6'
          h3.text-lg.font-bold.text-base-content
            = t('home.index.pillars.direct_senior.title')
          p.text-sm.text-neutral-600.leading-relaxed
            = t('home.index.pillars.direct_senior.body')
